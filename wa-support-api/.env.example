APP_NAME="WA Support"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug
# Verbose Meta/WhatsApp pipeline only. Laravel app path is wa-support-api/ in this monorepo:
#   tail -f wa-support-api/storage/logs/webhook.log
LOG_WEBHOOK_LEVEL=debug

# --- Database (required in production: copy this file to .env and set real values) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wa_support
DB_USERNAME=root
DB_PASSWORD=

# Optional: single URL instead of separate DB_* vars
# DB_URL=mysql://user:pass@127.0.0.1:3306/wa_support

SESSION_DRIVER=database
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

META_GRAPH_VERSION=v21.0
# Graph API Phone number ID for *this* inbox. Must match the line forwarded from WABA2 when using
# one Meta app + PARROT_SUPPORT_PHONE_NUMBER_IDS there; use string or number in .env, both work.
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ID=
WHATSAPP_TIMEOUT=30
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

# Firebase Cloud Messaging (HTTP v1). Required for push alerts; tail storage/logs/fcm.log
# FCM_PROJECT_ID must match the Firebase project used by the Flutter app (google-services.json).
# Place the service account JSON under storage/app/firebase/ (gitignored). On the server: chown www-data.
FCM_PROJECT_ID=parrotchatsupport
FCM_SERVICE_ACCOUNT_PATH=storage/app/firebase/parrotchatsupport-firebase-adminsdk-fbsvc-23df4baf3d.json

SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
